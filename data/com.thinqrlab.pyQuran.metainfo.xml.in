<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.thinqrlab.pyQuran</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <name>PyQuran</name>
  <summary>A Qur'an Application</summary>
  <description>
    <p>A simple Qur'an reader that works natively on linux.</p>
    <p>Multiple variants are available for download within the app if needed.</p>
    <ul>
      <li>Hafs (Old)</li>
      <li>Hafs (New)</li>
      <li>Hafs (Newest)</li>
      <li>Qaloon</li>
      <li>Warsh</li>
      </ul>
  </description>

  <developer id="tld.vendor">
    <name>mBilG</name>
  </developer>

  <!-- Required: Should be a link to the upstream homepage for the component -->
  <url type="homepage">https://github.com/mBilG/pyQuran</url>
  <!-- Recommended: It is highly recommended for open-source projects to display the source code repository -->
  <url type="vcs-browser">https://github.com/mBilG/pyQuran</url>
  <!-- Should point to the software's bug tracking system, for users to report new bugs -->
  <url type="bugtracker">https://github.com/mBilG/pyQuran/issues</url>
  <!-- This could for example be an HTTPS URL to an online form or a page describing how to contact the developer -->
  <url type="contact">https://www.thinqrlab.com/contact</url>
  <!-- URLs of this type should point to a webpage showing information on how to contribute to the described software project -->
  <url type="contribute">https://github.com/mBilG/pyQuran</url>

  <translation type="gettext">pyquran</translation>
  <!-- All graphical applications having a desktop file must have this tag in the MetaInfo.
     If this is present, appstreamcli compose will pull icons, keywords and categories from the desktop file. -->
  <launchable type="desktop-id">com.thinqrlab.pyQuran.desktop</launchable>
  <!-- Use the OARS website (https://hughsie.github.io/oars/generate.html) to generate these and make sure to use oars-1.1 -->
  <content_rating type="oars-1.1" />

  <!-- Applications should set a brand color in both light and dark variants like so -->
  <branding>
    <color type="primary" scheme_preference="light">#e57a44</color>
    <color type="primary" scheme_preference="dark">#31081f</color>
  </branding>

  <screenshots>
    <screenshot type="default">
      <image>https://github.com/mBilG/pyQuran/blob/master/screenshots/pyQuran_light_dual_page_sidebar.png</image>
      <caption>Dual page view with sidebar in light mode</caption>
    </screenshot>
    <screenshot>
      <image>https://github.com/mBilG/pyQuran/blob/master/screenshots/pyQuran_dark_overlay_sidebar.png</image>
      <caption>Single page view with sidebar as overlay in dark mode</caption>
    </screenshot>
    <screenshot>
      <image>https://github.com/mBilG/pyQuran/blob/master/screenshots/pyQuran_light_general.png</image>
      <caption>General options menu</caption>
    </screenshot>
    <screenshot>
      <image>https://github.com/mBilG/pyQuran/blob/master/screenshots/pyQuran_dark_download.png</image>
      <caption>Download interface</caption>
    </screenshot>

  </screenshots>

  <releases>
    <release version="49.0" date="2026-03-01">
      <url type="details">https://github.com/mBilG/pyQuran/releases</url>
      <description translate="no">
        <p>Updated codebase and performance improvements</p>
        <ul>
          <li>Version now matching GNOME runtime version</li>
          <li>Made initial package lighter by removing additional variants</li>
          <li>Additional variants now optional and available for download</li>
          <li>Added more fonts for Arabic Text in app (not pages)</li>
        </ul>
      </description>
    </release>
  </releases>

</component>
